@page "{id:int}"
@model KoiFarmShop.WebApplication.Pages.manager.Customers.DeleteModel
@{
    ViewData["Title"] = "Xóa Khách hàng";
    Layout = "~/Pages/Shared/_ManagerLayout.cshtml";
}

<div class="card shadow mb-4 border-left-danger">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa khách hàng
        </h6>
    </div>

    <div class="card-body">
        <div class="alert alert-danger">
            <h5 class="alert-heading">Bạn có chắc chắn muốn xóa khách hàng này không?</h5>
            <p class="mb-0">
                Hành động này sẽ xóa vĩnh viễn hồ sơ khách hàng <strong>@Model.Customer.CustomerName</strong> và tài khoản đăng nhập liên kết. <br />
                <strong>Lưu ý:</strong> Hành động này không thể hoàn tác!
            </p>
        </div>

        <div class="card mb-4 border-0">
            <div class="card-body bg-light rounded">
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted font-weight-bold">Mã khách hàng:</div>
                    <div class="col-sm-9 fw-bold text-primary">@Model.Customer.CustomerId</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted font-weight-bold">Họ và tên:</div>
                    <div class="col-sm-9 fw-bold">@Model.Customer.CustomerName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted font-weight-bold">Số điện thoại:</div>
                    <div class="col-sm-9">@Model.Customer.Phone</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted font-weight-bold">Email:</div>
                    <div class="col-sm-9">@Model.Customer.Email</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted font-weight-bold">Địa chỉ:</div>
                    <div class="col-sm-9">@Model.Customer.Address</div>
                </div>
            </div>
        </div>

        <form method="post">
            <input type="hidden" asp-for="Customer.CustomerId" />

            <div class="d-flex justify-content-between mt-4">
                <a asp-page="./Index" class="btn btn-secondary px-4">
                    <i class="bi bi-arrow-left me-1"></i> Hủy, quay lại
                </a>
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash-fill me-1"></i> Xác nhận Xóa
                </button>
            </div>
        </form>
    </div>
</div>