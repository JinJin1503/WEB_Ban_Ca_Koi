@page
@model KoiFarmShop.WebApplication.Pages.historydichvu.IndexModel
@{
    ViewData["Title"] = "Lịch sử dịch vụ";
}

<div class="container py-5">
    <header class="text-center mb-5">
        <h2 class="fw-bold text-uppercase">Quản lý lịch sử Ký gửi</h2>
        <p class="text-muted">Theo dõi trạng thái các đơn ký gửi cá Koi của bạn</p>
    </header>

    @if (Model.MyRequests == null || !Model.MyRequests.Any())
    {
        <div class="alert alert-info text-center shadow-sm border-0 py-4">
            <i class="fas fa-info-circle mb-2 fs-3"></i>
            <p class="mb-0">Bạn chưa có đơn ký gửi nào. Hãy trải nghiệm dịch vụ của chúng tôi nhé!</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr class="text-center">
                        <th class="py-3">Mã Đơn</th>
                        <th>Ngày gửi</th>
                        <th>Loại dịch vụ</th>
                        <th>Tên cá Koi</th>
                        <th>Giống cá</th>
                        <th>Trạng thái</th>
                        <th style="width: 200px;">Tiến độ chăm sóc</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.MyRequests)
                    {
                        <tr>
                            <td class="text-center fw-bold text-muted">#@item.RequestId</td>

                            <td class="text-center">@item.RequestDate.ToString("dd/MM/yyyy HH:mm")</td>

                            <td class="text-center">
                                @{
                                    var isBan = item.ConsignmentType == "Bán";
                                    var typeClass = isBan ? "bg-primary-subtle text-primary border-primary" : "bg-success-subtle text-success border-success";
                                    var icon = isBan ? "fa-store" : "fa-hand-holding-water";
                                }
                                <span class="badge border @typeClass px-3 py-2">
                                    <i class="fas @icon me-1"></i> @item.ConsignmentType
                                </span>
                            </td>

                            <td class="fw-bold text-dark">@item.KoiName</td>

                            <td class="text-center">@Model.TranslateCategory(item.KoiBreed)</td>

                            <td class="text-center">
                                <span class="badge rounded-pill @Model.GetStatusBadgeClass(item.Status) px-3 py-2">
                                    @Model.TranslateStatus(item.Status)
                                </span>
                            </td>

                            <td>
                                @if (item.ConsignmentType == "Chăm sóc" &&
                                                        (item.Status?.ToLower() == "đang chăm sóc" || item.Status?.ToLower() == "hoàn thành"))
                                {
                                    var startDate = item.ConsignmentDate;
                                    var endDate = startDate.AddMonths(item.ConsignmentDuration);
                                    var today = DateTime.Now;
                                    var totalDays = (endDate - startDate).TotalDays;
                                    var daysPassed = (today - startDate).TotalDays;

                                    if (daysPassed < 0) daysPassed = 0;
                                    if (daysPassed > totalDays) daysPassed = totalDays;

                                    var percent = totalDays > 0 ? (daysPassed / totalDays) * 100 : 0;
                                    var daysLeft = Math.Max(0, Math.Ceiling((endDate - today).TotalDays));

                                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.75rem; font-weight: 500;">
                                        <span class="text-muted">@startDate.ToString("dd/MM")</span>
                                        @if (daysLeft > 0)
                                        {
                                            <span class="text-danger">Còn @daysLeft ngày</span>
                                        }
                                        else
                                        {
                                            <span class="text-success">Đã xong</span>
                                        }
                                    </div>
                                    <div class="progress shadow-sm" style="height: 10px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated @(percent >= 100 ? "bg-success" : "bg-info")"
                                             role="progressbar"
                                             style="width: @percent%;"
                                             aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100">
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center text-muted fst-italic" style="font-size: 0.85rem;">-</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>