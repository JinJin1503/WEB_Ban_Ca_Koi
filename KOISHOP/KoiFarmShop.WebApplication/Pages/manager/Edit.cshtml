@page
@model KoiFarmShop.WebApplication.Pages.Manager.EditStaffModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Chỉnh Sửa Nhân Viên";
}

<h1>@ViewData["Title"]</h1>

<form method="post">
    <div class="form-group">
        <label for="Name">Tên Nhân Viên</label>
        <input type="text" class="form-control" id="Name" name="Name" value="@Model.ExistingStaff.StaffName" required />
    </div>

    <div class="form-group">
        <label for="Role">Vai Trò</label>
        <input type="text" class="form-control" id="Role" name="Role" value="@Model.ExistingStaff.Role" required />
    </div>

    <button type="submit" class="btn btn-warning">Cập Nhật Nhân Viên</button>
</form>
