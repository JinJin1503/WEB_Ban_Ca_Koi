@page
@model KoiFarmShop.WebApplication.Pages.Manager.DetailsStaffModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Chi Tiết Nhân Viên";
}

<h1>@ViewData["Title"]</h1>

<div>
    <p><strong>ID:</strong> @Model.StaffDetails.StaffId</p>
    <p><strong>Tên Nhân Viên:</strong> @Model.StaffDetails.StaffName</p>
    <p><strong>Vai Trò:</strong> @Model.StaffDetails.Role</p>
    <p><strong>Ngày Tham Gia:</strong> @Model.StaffDetails.JoinDate.ToShortDateString()</p>
    <a class="btn btn-warning" href="/manager/Edit?staffId=@Model.StaffDetails.StaffId">Sửa</a>
    <a class="btn btn-danger" href="/manager/Delete?staffId=@Model.StaffDetails.StaffId">Xóa</a>
    <a class="btn btn-secondary" href="/manager/Index">Quay lại danh sách</a>
</div>
