@{
    Layout = null;
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    bool isStaffManagement = currentPath.StartsWith("/manager", System.StringComparison.OrdinalIgnoreCase)
        && !currentPath.StartsWith("/manager/products", System.StringComparison.OrdinalIgnoreCase);
    bool isProductManagement = currentPath.StartsWith("/manager/products", System.StringComparison.OrdinalIgnoreCase)
        || currentPath.StartsWith("/Product/Create", System.StringComparison.OrdinalIgnoreCase)
        || currentPath.StartsWith("/Product/Edit", System.StringComparison.OrdinalIgnoreCase)
        || currentPath.StartsWith("/Product/Delete", System.StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - KoiFarm Admin</title>
    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-page="/manager/Index">KoiFarm Admin</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav" aria-controls="adminNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="adminNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(isStaffManagement ? "active" : null)" asp-page="/manager/Index">Quản lý nhân viên</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(isProductManagement ? "active" : null)" asp-page="/manager/Products">Quản lý sản phẩm</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Manager/ManageConsignment">Quản Lý Ký Gửi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Trangchu/Index">Về trang chủ</a>
                    </li>
                </ul>
                <a class="btn btn-outline-light btn-sm" asp-page="/Logout">Đăng xuất</a>
            </div>
        </div>
    </nav>

    <main class="py-4">
        <div class="container">
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">Khu vực</div>
                            <h5 class="mb-0">Trang quản trị</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">Tác vụ nhanh</div>
                            <a class="btn btn-primary btn-sm me-2" asp-page="/manager/Products">Sản phẩm</a>
                            <a class="btn btn-outline-primary btn-sm" asp-page="/Product/Create">Thêm cá Koi</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">Quyền hiện tại</div>
                            <h6 class="mb-0">Manager</h6>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </main>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/main.js"></script>
</body>
</html>
