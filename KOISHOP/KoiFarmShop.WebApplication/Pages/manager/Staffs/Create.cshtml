@page
@model KoiFarmShop.WebApplication.Pages.manager.Staffs.CreateModel
@{
    ViewData["Title"] = "Thêm nhân viên mới";
    Layout = "~/Pages/Shared/_ManagerLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Nhập thông tin nhân viên</h6>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 border-right">
                            <h5 class="text-muted mb-3">Thông tin đăng nhập</h5>

                            <div class="form-group mb-3">
                                <label class="control-label fw-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                                <input asp-for="Input.UserName" class="form-control" placeholder="Ví dụ: nhanvien1" />
                                <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="control-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="Input.Password" type="password" class="form-control" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h5 class="text-muted mb-3">Thông tin hồ sơ</h5>

                            <div class="form-group mb-3">
                                <label class="control-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="Input.StaffName" class="form-control" />
                                <span asp-validation-for="Input.StaffName" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="control-label fw-bold">Email <span class="text-danger">*</span></label>
                                <input asp-for="Input.Email" class="form-control" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="control-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="Input.Phone" class="form-control" />
                                <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="control-label fw-bold">Lương cơ bản (VNĐ)</label>
                                <input asp-for="Input.Salary" type="number" class="form-control" value="5000000" />
                                <span asp-validation-for="Input.Salary" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="control-label fw-bold">Vai trò <span class="text-danger">*</span></label>
                                <select asp-for="Input.Role" class="form-control">
                                    <option value="">-- Chọn vai trò --</option>
                                    <option value="Manager">Manager</option>
                                    <option value="Staff">Staff</option>
                                </select>
                                <span asp-validation-for="Input.Role" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr />
                    <div class="form-group mt-3 text-center">
                        <a asp-page="./Index" class="btn btn-secondary me-2">Quay lại danh sách</a>
                        <button type="submit" class="btn btn-primary">Lưu nhân viên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}