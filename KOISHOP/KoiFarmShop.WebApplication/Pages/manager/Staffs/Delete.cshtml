@page "{id:int}"
@model KoiFarmShop.WebApplication.Pages.manager.Staffs.DeleteModel
@{
    ViewData["Title"] = "Xóa Nhân Viên";
    Layout = "~/Pages/Shared/_ManagerLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow mb-4 border-bottom-danger">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-danger"><i class="fas fa-exclamation-triangle"></i> Cảnh báo xóa nhân viên</h6>
            </div>
            <div class="card-body">
                <h5 class="text-danger mb-4">Bạn có chắc chắn muốn xóa nhân viên này không? Hành động này không thể hoàn tác!</h5>

                <div class="mb-3 bg-light p-3 rounded">
                    <p><strong>Mã NV:</strong> @Model.StaffToDelete.StaffId</p>
                    <p><strong>Họ và tên:</strong> @Model.StaffToDelete.StaffName</p>
                    <p><strong>Email:</strong> @Model.StaffToDelete.Email</p>
                    <p><strong>Vai trò:</strong> <span class="badge bg-danger">@Model.StaffToDelete.Role</span></p>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="StaffToDelete.StaffId" />
                    <hr />
                    <div class="form-group mt-3 text-center">
                        <a asp-page="./Index" class="btn btn-secondary me-2">Hủy, quay lại</a>
                        <button type="submit" class="btn btn-danger">Xác nhận Xóa</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>