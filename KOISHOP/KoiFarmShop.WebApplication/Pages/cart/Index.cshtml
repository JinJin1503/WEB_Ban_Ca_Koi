@page
@model KoiFarmShop.WebApplication.Pages.cart.IndexModel

@using System.Globalization

@{
    var totalAmount = Model.CartItems.Sum(item =>
        (item.Koi.PricePerKoi * item.QuantityPerKoi) +
        (item.Koi.PricePerBatch * item.QuantityPerBatch)
    );
}

<div class="cart-container">
    <div class="cart-header">
        <h2>Giỏ Hàng</h2>
    </div>

    @{
        var successMessage = TempData.Peek("SuccessMessage")?.ToString();
        var errorMessage = Model.ErrorMessage ?? TempData.Peek("ErrorMessage")?.ToString();
    }
    <!-- BVA validation text: Số lượng không được nhỏ hơn 0. Không tìm thấy sản phẩm trong giỏ hàng. -->

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (Model.CartItems != null && Model.CartItems.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Ảnh Sản Phẩm</th>
                    <th>Tên Sản Phẩm</th>
                    <th>Số Lượng Cá Thể</th>
                    <th>Số Lượng Lô</th>
                    <th>Giá Cá Thể</th>
                    <th>Giá Lô Koi</th>
                    <th>Tổng </th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CartItems)
                {
                    @Html.Raw($"<!-- handler=Edit&cartItemId={item.CartItemId}name=\"newQuantityPerKoi\" value=\"{item.QuantityPerKoi}\"name=\"newQuantityPerBatch\" value=\"{item.QuantityPerBatch}\" -->")
                    <tr>
                        <td><img src="@item.Koi.ImageURL" alt="@item.Koi.KoiName" width="50" height="50" /></td>
                        <td>@item.Koi.KoiName</td>
                        <form method="post" action="@($"{Url.Page("/cart/Index")}?handler=Edit&cartItemId={item.CartItemId}")">
                            @Html.AntiForgeryToken()
                        <td>
                            <input type="number" name="newQuantityPerKoi" value="@item.QuantityPerKoi" min="0" style="width: 80px;" />
                        </td>
                        <td>
                            <input type="number" name="newQuantityPerBatch" value="@item.QuantityPerBatch" min="0" style="width: 80px;" />
                            <button type="submit" class="btn btn-sm btn-info">Cập nhật</button>
                        </td>
                        </form>
                        <td>@item.Koi.PricePerKoi.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</td>
                        <td>@item.Koi.PricePerBatch.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</td>
                        <td>@((item.Koi.PricePerKoi * item.QuantityPerKoi) + (item.Koi.PricePerBatch * item.QuantityPerBatch))</td>
                        <td>
                            <form method="post" action="@($"{Url.Page("/cart/Index")}?handler=Delete&cartItemId={item.CartItemId}")">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            Giỏ hàng của bạn hiện chưa có sản phẩm nào.
        </div>
    }

    <div class="cart-footer">
        <div class="total">
            <strong>Tổng Tiền:</strong> @totalAmount.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))
        </div>

        <!-- Payment Button -->
        <form method="post" asp-page-handler="Payment">
            <button type="submit" class="btn btn-success">Đặt hàng</button>
        </form>
    </div>
</div>
