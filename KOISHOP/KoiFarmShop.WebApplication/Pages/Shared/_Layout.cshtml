@using KoiFarmShop.WebApplication.Security
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var username = isAuthenticated ? User.Identity?.Name : null;
    var isManager = User.IsInRole(AppRoles.Manager);
    var isCustomer = User.IsInRole(AppRoles.Customer);
    var roleLabel = isManager ? "Quản lý" : (isCustomer ? "Khách hàng" : "Nhân viên");
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link href="assets/img/favicon.png" rel="icon">
    <link href="assets/img/apple-touch-icon.png" rel="apple-touch-icon">

    <link href="https://fonts.gstatic.com" rel="preconnect">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Nunito:300,300i,400,400i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i" rel="stylesheet">

    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/vendor/boxicons/css/boxicons.min.css" rel="stylesheet">
    <link href="~/vendor/quill/quill.snow.css" rel="stylesheet">
    <link href="~/vendor/quill/quill.bubble.css" rel="stylesheet">
    <link href="~/vendor/remixicon/remixicon.css" rel="stylesheet">
    <link href="~/vendor/simple-datatables/style.css" rel="stylesheet">

    <link href="~/css/style.css" rel="stylesheet">
</head>

<body>
    <header id="header" class="header fixed-top d-flex align-items-center">
        <div class="d-flex align-items-center justify-content-between">
            <a asp-page="/Trangchu/Index" class="logo d-flex align-items-center">
                <img src="~/images/logo.jpg" alt="">
                <span class="d-none d-lg-block">KoiFarmShop</span>
            </a>
            <i class="bi bi-list toggle-sidebar-btn"></i>
        </div>

        <div class="search-bar">
            <form class="search-form d-flex align-items-center" method="get" asp-page="/Product/Index">
                <input type="text" name="keyword" placeholder="Nhập từ khóa tìm kiếm..." title="Nhập từ khóa tìm kiếm" required>
                <button type="submit" title="Tìm kiếm"><i class="bi bi-search"></i></button>
            </form>
        </div>

        <nav class="header-nav ms-auto">
            <ul class="d-flex align-items-center">
                <li class="nav-item d-block d-lg-none">
                    <a class="nav-link nav-icon search-bar-toggle" href="#">
                        <i class="bi bi-search"></i>
                    </a>
                </li>

                <li class="nav-item dropdown pe-3">
                    <a class="nav-link nav-profile d-flex align-items-center pe-0" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                        @if (isAuthenticated)
                        {
                            <span class="d-none d-md-block dropdown-toggle ps-2">@username</span>
                        }
                        else
                        {
                            <span class="d-none d-md-block dropdown-toggle ps-2">Chưa đăng nhập</span>
                        }
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-arrow profile">
                        <li class="dropdown-header">
                            @if (isAuthenticated)
                            {
                                <h6>@username</h6>
                                <span>@roleLabel</span>
                            }
                            else
                            {
                                <h6>Chưa đăng nhập</h6>
                                <span>Vui lòng đăng nhập để sử dụng các chức năng dành cho thành viên.</span>
                            }
                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        @if (User.Identity.IsAuthenticated && User.IsInRole("Customer"))
                        {
                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Profile/Index">
                                    <i class="bi bi-person"></i>
                                    <span>Hồ sơ</span>
                                </a>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Login/Logout">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Thoát</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Login/Login">
                                    <i class="bi bi-box-arrow-in-right"></i>
                                    <span>Đăng nhập</span>
                                </a>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-page="/Register/Register">
                                    <i class="bi bi-card-list"></i>
                                    <span>Đăng ký</span>
                                </a>
                            </li>
                        }
                    </ul>
                </li>
            </ul>
        </nav>
    </header>

    <aside id="sidebar" class="sidebar">
        <ul class="sidebar-nav" id="sidebar-nav">
            @if (User.IsInRole(AppRoles.Manager) || User.IsInRole(AppRoles.Staff))
            {
                <li class="nav-item">
                    <a class="nav-link collapsed" asp-page="/manager/Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Trang admin</span>
                    </a>
                </li>
            }

            <li class="nav-item">
                <a class="nav-link" asp-page="/Trangchu/Index">
                    <i class="bi bi-grid"></i>
                    <span>Trang chủ</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link collapsed" asp-page="/Product/Index">
                    <i class="bi bi-menu-button-wide"></i>
                    <span>Sản phẩm</span>
                </a>
            </li>
           
            <li class="nav-item">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#cart-menu" role="button" aria-expanded="false" aria-controls="cart-menu">
                    <i class="bi bi-cart"></i>
                    <span>Giỏ hàng</span>
                </a>
                <ul id="cart-menu" class="collapse nav-content" data-bs-parent="#sidebar-nav">
                    <li>
                        <a asp-page="/cart/Index">
                            <i class="bi bi-cart"></i>
                            <span>Xem giỏ hàng</span>
                        </a>
                    </li>
                </ul>
            </li>

            <li class="nav-item">
                <a class="nav-link collapsed" data-bs-target="#charts-nav" data-bs-toggle="collapse" href="#">
                    <i class="bi bi-gear"></i>
                    <span>Dịch vụ</span>
                </a>
                <ul id="charts-nav" class="nav-content collapse" data-bs-parent="#sidebar-nav">
                    <li>
                        <a asp-page="/Dichvuchamsoc/IndexCare">
                            <i class="bi bi-circle"></i>
                            <span>Ký gửi chăm sóc</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Dichvukiban/Index">
                            <i class="bi bi-circle"></i>
                            <span>Ký gửi bán</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/history_dichvu/History">
                            <i class="bi bi-circle"></i>
                            <span>Lịch sử dịch vụ</span>
                        </a>
                    </li>
                </ul>
            </li>

            <li class="nav-item">
                <a class="nav-link collapsed" asp-page="/F.A.Q/Index">
                    <i class="bi bi-question-circle"></i>
                    <span>F.A.Q</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link collapsed" asp-page="/Contact/Index">
                    <i class="bi bi-envelope"></i>
                    <span>Liên hệ</span>
                </a>
            </li>

            @if (User.Identity.IsAuthenticated && User.IsInRole("Customer"))
            {
                <li class="nav-item">
                    <a class="nav-link collapsed" asp-page="/Profile/Index">
                        <i class="bi bi-person"></i>
                        <span>Hồ sơ</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link collapsed" asp-page="/Login/Logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Đăng xuất</span>
                    </a>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <a class="nav-link collapsed" asp-page="/Register/Register">
                        <i class="bi bi-card-list"></i>
                        <span>Đăng ký</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link collapsed" asp-page="/Login/Login">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Đăng nhập</span>
                    </a>
                </li>
            }
        </ul>
    </aside>

    <main id="main" class="main">
        @RenderBody()
    </main>

    <footer id="footer" class="footer">
        <div class="footer-top">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4 col-md-6 footer-info">
                        <h3>KoiFarmShop</h3>
                        <p>
                            Địa chỉ: 81 Xuân Thới 22, Xuân Thới Đông, Hóc Môn, TP.HCM<br>
                            Điện thoại: 0905681918<br>
                            Email: Khanhng5776@ut.edu.vn<br>
                        </p>
                        <div class="social-links">
                            <a href="https://www.facebook.com/khan.ngogia?mibextid=LQQJ4d" class="facebook"><i class="bi bi-facebook"></i></a>
                            <a href="https://www.instagram.com/yoonjin_1503/profilecard/?igsh=MXZ4YjhrdmZ0cXFwMA==" class="instagram"><i class="bi bi-instagram"></i></a>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6 footer-links">
                        <h4>Sản phẩm - Dịch vụ</h4>
                        <ul>
                            <li><i class="bi bi-chevron-right"></i> <a asp-page="/Product/Index">Cá Koi nhập khẩu</a></li>
                            <li><i class="bi bi-chevron-right"></i> <a asp-page="/Product/Index">Cá Koi lai F1</a></li>
                            <li><i class="bi bi-chevron-right"></i> <a asp-page="/Product/Index">Cá Koi thuần Việt</a></li>
                            <li><i class="bi bi-chevron-right"></i> <a asp-page="/Dichvu/chamsoc">Chăm sóc cá Koi</a></li>
                            <li><i class="bi bi-chevron-right"></i> <a asp-page="/Dichvu/Consignment">Ký gửi cá Koi</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-4 col-md-6 footer-support">
                        <h4>Hỗ trợ khách hàng</h4>
                        <p>Liên hệ ngay khi bạn cần hỗ trợ hoặc tư vấn về các dịch vụ của chúng tôi:</p>
                        <ul>
                            <li><i class="bi bi-telephone"></i> Hotline: 0344883755</li>
                            <li><i class="bi bi-envelope"></i> Email: dihny5348@ut.edu.vn</li>
                            <li><i class="bi bi-clock"></i> Giờ làm việc: 9:00 - 17:00 (Thứ 2 - Thứ 6)</li>
                        </ul>
                        <div class="social-links">
                            <a href="https://www.facebook.com/huynhngoyendi?mibextid=LQQJ4d" class="facebook"><i class="bi bi-facebook"></i></a>
                            <a href="https://www.instagram.com/huynhngoyendi?igsh=MTgxbGE0YngyeXE5ZA==" class="instagram"><i class="bi bi-instagram"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container d-md-flex py-4">
            <div class="me-md-auto text-center text-md-start">
                <div class="copyright">
                    <strong><span>KoiFarmShop</span></strong>
                </div>
                <div class="credits">
                    Designed by <a href="https://www.facebook.com/huynhngoyendi?mibextid=LQQJ4d">Team Gia Khánh- Yến Di</a>
                </div>
            </div>
        </div>
    </footer>

    <a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <script src="~/vendor/apexcharts/apexcharts.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/vendor/chart.js/chart.umd.js"></script>
    <script src="~/vendor/echarts/echarts.min.js"></script>
    <script src="~/vendor/quill/quill.js"></script>
    <script src="~/vendor/simple-datatables/simple-datatables.js"></script>
    <script src="~/vendor/tinymce/tinymce.min.js"></script>
    <script src="~/vendor/php-email-form/validate.js"></script>

    <script src="~/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)


</body>

</html>
