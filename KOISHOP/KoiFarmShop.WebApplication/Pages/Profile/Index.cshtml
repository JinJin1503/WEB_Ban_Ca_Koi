@page
@model KoiFarmShop.WebApplication.Pages.Profile.IndexModel
@{
}
<main id="main" class="main">


    </nav>
    </div><!-- End Page Title -->

    <section class="section profile">
        <div class="row">

            <div class="col-xl-4">
                <div class="card">
                    <div class="card-body profile-card pt-5 d-flex flex-column align-items-center">
                        <h2>@Model.UserProfile?.FullName</h2>
                        <h3 class="text-muted mt-2">Khách hàng</h3>
                    </div>
                </div>
            </div>

            <div class="col-xl-8">
                <div class="card">
                    <div class="card-body pt-3">

                        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                @Model.SuccessMessage
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @Model.ErrorMessage
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <ul class="nav nav-tabs nav-tabs-bordered">
                            <li class="nav-item">
                                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#profile-overview">Giới thiệu</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#profile-edit">Chỉnh sửa hồ sơ</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#profile-settings">Cài đặt</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#profile-change-password">Mật khẩu</button>
                            </li>
                        </ul>

                        <div class="tab-content pt-2">
                            <div class="tab-pane fade show active profile-overview" id="profile-overview">
                                <h5 class="card-title mb-4">Chi tiết hồ sơ</h5>

                                <div class="row mb-3">
                                    <label class="col-md-4 col-lg-3 col-form-label fw-bold">Họ và tên</label>
                                    <div class="col-md-8 col-lg-9">
                                        <input type="text" class="form-control bg-light" value="@Model.UserProfile?.FullName" readonly>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <label class="col-md-4 col-lg-3 col-form-label fw-bold">Địa chỉ</label>
                                    <div class="col-md-8 col-lg-9">
                                        <input type="text" class="form-control bg-light" value="@Model.UserProfile?.Address" readonly>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <label class="col-md-4 col-lg-3 col-form-label fw-bold">Điện thoại</label>
                                    <div class="col-md-8 col-lg-9">
                                        <input type="text" class="form-control bg-light" value="@Model.UserProfile?.Phone" readonly>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <label class="col-md-4 col-lg-3 col-form-label fw-bold">Email</label>
                                    <div class="col-md-8 col-lg-9">
                                        <input type="email" class="form-control bg-light" value="@Model.UserProfile?.Email" readonly>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade profile-edit pt-3" id="profile-edit">
                                <form method="post" asp-page-handler="UpdateProfile">
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Họ và tên</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input asp-for="UserProfile.FullName" type="text" class="form-control">
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Địa chỉ</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input asp-for="UserProfile.Address" type="text" class="form-control">
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Điện thoại</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input asp-for="UserProfile.Phone" type="text" class="form-control">
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Email</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input asp-for="UserProfile.Email" type="email" class="form-control">
                                        </div>
                                    </div>
                                    <div class="text-center mt-4">
                                        <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                                    </div>
                                </form>
                            </div>

                            <div class="tab-pane fade pt-3" id="profile-settings">
                                <form method="post" asp-page-handler="UpdateSettings">
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Email thông báo</label>
                                        <div class="col-md-8 col-lg-9">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="newProducts" checked>
                                                <label class="form-check-label" for="newProducts">Thông tin sản phẩm mới</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="proOffers">
                                                <label class="form-check-label" for="proOffers">Khuyến mãi & Tiếp thị</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-center mt-4">
                                        <button type="submit" class="btn btn-primary px-4">Lưu Cài đặt</button>
                                    </div>
                                </form>
                            </div>

                            <div class="tab-pane fade pt-3" id="profile-change-password">
                                <form method="post" asp-page-handler="ChangePassword">
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Mật khẩu hiện tại</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input asp-for="PasswordModel.CurrentPassword" type="password" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Mật khẩu mới</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input asp-for="PasswordModel.NewPassword" type="password" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label class="col-md-4 col-lg-3 col-form-label">Xác nhận mật khẩu</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input asp-for="PasswordModel.ConfirmPassword" type="password" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="text-center mt-4">
                                        <button type="submit" class="btn btn-primary px-4">Đổi Mật khẩu</button>
                                    </div>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main><!-- End #main -->