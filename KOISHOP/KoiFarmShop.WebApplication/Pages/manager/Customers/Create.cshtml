@page
@model KoiFarmShop.WebApplication.Pages.manager.Customers.CreateModel
@{
    ViewData["Title"] = "Thêm Khách hàng";
    Layout = "~/Pages/Shared/_ManagerLayout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Thêm Khách hàng mới</h6>
        <a asp-page="./Index" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-body">
        <form method="post" class="needs-validation" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="p-3 border rounded bg-light">
                        <h6 class="text-primary border-bottom pb-2 mb-3">Thông tin tài khoản đăng nhập</h6>

                        <div class="mb-3">
                            <label asp-for="Input.UserName" class="form-label font-weight-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input asp-for="Input.UserName" class="form-control" placeholder="Nhập tên đăng nhập viết liền không dấu" required />
                            <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label font-weight-bold">Mật khẩu <span class="text-danger">*</span></label>
                            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Tối thiểu 8 ký tự" required />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="p-3 border rounded">
                        <h6 class="text-primary border-bottom pb-2 mb-3">Hồ sơ khách hàng</h6>

                        <div class="mb-3">
                            <label asp-for="Input.CustomerName" class="form-label font-weight-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="Input.CustomerName" class="form-control" placeholder="Nhập họ và tên đầy đủ" required />
                            <span asp-validation-for="Input.CustomerName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Phone" class="form-label font-weight-bold">Số điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Input.Phone" class="form-control" placeholder="Ví dụ: 0901234567" required />
                            <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label font-weight-bold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Input.Email" type="email" class="form-control" placeholder="Ví dụ: email@domain.com" required />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Address" class="form-label font-weight-bold">Địa chỉ <span class="text-danger">*</span></label>
                            <input asp-for="Input.Address" class="form-control" placeholder="Nhập địa chỉ nhận cá" required />
                            <span asp-validation-for="Input.Address" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-success px-4"><i class="bi bi-save me-1"></i> Lưu thông tin</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}