@page
@model KoiFarmShop.WebApplication.Pages.Manager.Consignment.DetailsConsignmentModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Chi Tiết Đơn Ký Gửi";
    ViewData["HideDashboard"] = true;
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Chi Tiết Đơn Ký Gửi #@Model.ConsignmentRequest.RequestId</h2>
        <a href="/manager/Consignment/ManageConsignment" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Thông Tin Chung</h5>
                </div>
                <div class="card-body">
                    <p><strong>Khách hàng:</strong> @Model.ConsignmentRequest.Customer?.CustomerName</p>
                    <p>
                        <strong>Loại dịch vụ:</strong>
                        <span class="badge @(Model.ConsignmentRequest.ConsignmentType == "Bán" ? "bg-info" : "bg-success")">
                            @Model.ConsignmentRequest.ConsignmentType
                        </span>
                    </p>
                    <p><strong>Ngày gửi yêu cầu:</strong> @Model.ConsignmentRequest.RequestDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p>
                        <strong>Trạng thái hiện tại:</strong>
                        <span class="badge @(Model.ConsignmentRequest.Status == "Approved" ? "bg-secondary" : "bg-warning text-dark")">
                            @Model.ConsignmentRequest.Status
                        </span>
                    </p>
                    @if (Model.ConsignmentRequest.CareService)
                    {
                        <p><strong>Yêu cầu đặc biệt:</strong> <span class="text-danger fw-bold">Có sử dụng dịch vụ chăm sóc</span></p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-fish"></i> Hồ Sơ Cá Koi</h5>
                </div>
                <div class="card-body">
                    <p><strong>Tên cá:</strong> @Model.ConsignmentRequest.KoiName</p>
                    <p><strong>Giống cá (Breed):</strong> @Model.ConsignmentRequest.KoiBreed</p>
                    <p><strong>Tuổi:</strong> @Model.ConsignmentRequest.KoiAge tháng</p>
                    <p><strong>Kích thước:</strong> @Model.ConsignmentRequest.KoiSize cm</p>
                    <p><strong>Mô tả chi tiết:</strong> @Model.ConsignmentRequest.Remarks</p>
                    <hr />
                    <p class="mb-2"><strong>Hình ảnh đính kèm:</strong></p>
                    @if (!string.IsNullOrEmpty(Model.ConsignmentRequest.KoiImage))
                    {
                        <div class="text-center">
                            <img src="@Model.ConsignmentRequest.KoiImage" alt="Ảnh cá Koi ký gửi" class="img-fluid rounded shadow" style="max-height: 350px; object-fit: cover;" />
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary text-center py-2 mb-0" role="alert">
                            <i class="fas fa-image text-muted me-2"></i>
                            <span class="fst-italic text-muted">Khách hàng không gửi hình ảnh</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="ConsignmentRequest.RequestId" name="id" />

        <div class="mt-4 mb-4">
            @if (Model.ConsignmentRequest.Status == "Chờ duyệt")
            {
                <button type="submit" asp-page-handler="Approve" class="btn btn-success me-2">Phê duyệt</button>

                <button type="submit" asp-page-handler="Reject" class="btn btn-danger" formnovalidate>Từ chối</button>
            }
            else if (Model.ConsignmentRequest.Status == "Approved")
            {
                <button type="submit" asp-page-handler="ReceiveKoi" class="btn btn-info text-white">Xác nhận: Đã nhận cá</button>
            }
            else if (Model.ConsignmentRequest.Status == "Đã nhận cá")
            {
                <button type="submit" asp-page-handler="StartCare" class="btn btn-primary me-2">Đưa vào chăm sóc</button>
                <button type="submit" asp-page-handler="Sold" class="btn btn-warning">Xác nhận: Đã bán</button>
            }

            <a asp-page="./ManageConsignment" class="btn btn-secondary ms-2">Quay lại danh sách</a>
        </div>
    </form>
