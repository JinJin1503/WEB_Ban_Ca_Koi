@page
@model KoiFarmShop.WebApplication.Pages.dichvukiban.IndexModel


<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ký gửi cá Koi</title>
    <!-- Đảm bảo đã bao gồm Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container py-5">
        <h1 class="text-center mb-4">Dịch vụ ký gửi bán cá Koi</h1>

        <div class="row justify-content-center">
            <!-- Mô tả thông tin cá -->
            <div class="col-md-6">
                <h3 class="mb-3 text-center">Thông tin ký gửi</h3>
                <form method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label asp-for="ConsignmentRequest.KoiName" class="form-label">Tên cá Koi</label>
                        <input asp-for="ConsignmentRequest.KoiName" class="form-control" required />
                        <span asp-validation-for="ConsignmentRequest.KoiName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConsignmentRequest.KoiAge" class="form-label">Tuổi cá (năm)</label>
                        <input asp-for="ConsignmentRequest.KoiAge" class="form-control" required />
                        <span asp-validation-for="ConsignmentRequest.KoiAge" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConsignmentRequest.KoiSize" class="form-label">Kích thước cá (cm)</label>
                        <input asp-for="ConsignmentRequest.KoiSize" class="form-control" required />
                        <span asp-validation-for="ConsignmentRequest.KoiSize" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConsignmentRequest.KoiBreed" class="form-label">Giống cá</label>
                        <select asp-for="ConsignmentRequest.KoiBreed" class="form-select" required>
                            <option value="">-- Chọn giống cá --</option>
                            <option value="Imported">Nhập khẩu</option>
                            <option value="Domestic">Thuần Việt</option>
                            <option value="Hybrid">Lai F1</option>
                        </select>
                        <span asp-validation-for="ConsignmentRequest.KoiBreed" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConsignmentRequest.ConsignmentFee" class="form-label">Giá cá (VND)</label>
                        <input asp-for="ConsignmentRequest.ConsignmentFee" type="number" min="0" class="form-control" required />
                        <span asp-validation-for="ConsignmentRequest.ConsignmentFee" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConsignmentRequest.Remarks" class="form-label">Mô tả cá</label>
                        <textarea asp-for="ConsignmentRequest.Remarks" class="form-control" rows="3" required></textarea>
                        <span asp-validation-for="ConsignmentRequest.Remarks" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConsignmentRequest.KoiImage" class="form-label">Hình ảnh cá Koi</label>
                        <input asp-for="ImageUpload" type="file" accept="image/*" class="form-control" />
                    </div>

                    <div class="mb-3 text-center">
                        <button type="submit" class="btn btn-success">Xác nhận ký gửi</button>
                    </div>
                </form>
            </div>
        </div>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>