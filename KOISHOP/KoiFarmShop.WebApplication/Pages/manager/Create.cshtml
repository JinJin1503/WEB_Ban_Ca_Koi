@page
@model KoiFarmShop.WebApplication.Pages.Manager.CreateStaffModel
@{
    Layout = "_ManagerLayout";

    ViewData["Title"] = "Thêm Nhân Viên Mới";
}

<h1>@ViewData["Title"]</h1>

<form method="post">
    <div class="form-group">
        <label for="Name">Tên Nhân Viên</label>
        <input type="text" class="form-control" id="Name" name="Name" value="@Model.NewStaff.StaffName" required />
    </div>

    <div class="form-group">
        <label for="Role">Vai Trò</label>
        <input type="text" class="form-control" id="Role" name="Role" value="@Model.NewStaff.Role" required />
    </div>

    <button type="submit" class="btn btn-primary">Thêm Nhân Viên</button>
</form>
