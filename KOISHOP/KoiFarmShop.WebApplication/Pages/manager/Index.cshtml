@page
@model KoiFarmShop.WebApplication.Pages.Manager.IndexModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Hệ thống Quản trị KoiFarm";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Dashboard Tổng quan</h1>
        <form method="get" class="form-inline">
            <select name="SelectedMonth" class="custom-select custom-select-sm shadow-sm" onchange="this.form.submit()">
                <option value="">Lọc theo tháng (Tất cả)</option>
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(Model.SelectedMonth == i)">Tháng @i</option>
                }
            </select>
        </form>
    </div>

    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Doanh thu (Tháng @(Model.SelectedMonth ?? DateTime.Now.Month))</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalRevenue.ToString("N0") đ</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Khách hàng mới</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalCustomers</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Ký gửi Bán (Thành công)</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.SuccessSaleConsignments đơn</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Ký gửi Chăm sóc (Thành công)</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.SuccessCareConsignments đơn</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-6 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Cơ cấu nguồn thu</h6></div>
                <div class="card-body">
                    <div class="chart-pie pt-4 pb-2"><canvas id="myPieChart"></canvas></div>
                    <div id="chart-legend" class="mt-4 text-center small text-muted">
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Danh sách khách hàng</h6></div>
                <div class="card-body" style="max-height: 360px; overflow-y: auto;">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>Tên khách hàng</th><th>Ngày đăng ký</th></tr></thead>
                        <tbody>
                            @foreach (var c in Model.CustomerList)
                            {
                                <tr><td>@c.CustomerName</td><td>@c.RegistrationDate.ToString("dd/MM/yyyy")</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById("myPieChart");
        var myPieChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ["Bán cá", "Phí Chăm sóc", "Hoa hồng Bán hộ"],
                datasets: [{
                    data: [@Model.OrderRevenue, @Model.CareConsignmentRevenue, @Model.SaleConsignmentRevenue],
                    backgroundColor: ['#4e73df', '#f6c23e', '#1cc88a'],
                    hoverBorderColor: "rgba(234, 236, 244, 1)",
                }],
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'bottom', // Đưa chú thích xuống dưới biểu đồ như bạn muốn
                        labels: { padding: 20, usePointStyle: true }
                    }
                },
                cutout: '75%'
            }
        });
    </script>
}