@page
@model KoiFarmShop.WebApplication.Pages.Trangchu.IndexModel

<section class="section">
    <div class="row justify-content-center">
        <!-- Dùng justify-content-center để căn giữa dòng -->
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body text-center">
                    <!-- Slides only carousel -->
                    <div id="carouselExampleSlidesOnly" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="~/images/1.png" class="d-block w-100" alt="...">
                            </div>
                            <div class="carousel-item">
                                <img src="~/images/2.png" class="d-block w-100" alt="...">
                            </div>
                            <div class="carousel-item">
                                <img src="~/images/3.png" class="d-block w-100" alt="...">
                            </div>
                        </div>
                    </div><!-- End Slides only carousel-->
                    <!-- Features Section -->
                    <section id="features" class="py-5">
                        <div class="container">
                            <section class="features-section py-5">
                                <div class="container">
                                    <h2 class="section-title text-center mb-5">Tính Năng Nổi Bật</h2>
                                    <div class="row text-center">
                                        <!-- Đa Dạng Giống Cá -->
                                        <div class="col-md-4">
                                            <div class="feature-card p-4 border rounded shadow-lg">
                                                <div class="video-container mb-3">
                                                    <video class="w-100 rounded" autoplay loop muted controls>
                                                        <source src="~/images/koivideo.mp4" type="video/mp4">
                                                        Your browser does not support the video tag.
                                                    </video>
                                                </div>
                                                <h4 class="mt-3">Đa Dạng Giống Cá</h4>
                                                <p>Các giống cá Koi nhập khẩu và lai tạo chất lượng cao.</p>
                                            </div>
                                        </div>

                                        <!-- Chăm Sóc Tận Tâm -->
                                        <div class="col-md-4">
                                            <div class="feature-card p-4 border rounded shadow-lg">
                                                <div class="video-container mb-3">
                                                    <video class="w-100 rounded" autoplay loop muted controls>
                                                        <source src="~/images/chamsocca.mp4" type="video/mp4">
                                                        Your browser does not support the video tag.
                                                    </video>
                                                </div>
                                                <h4 class="mt-3">Chăm Sóc Tận Tâm</h4>
                                                <p>Dịch vụ chăm sóc chuyên nghiệp cho từng chú cá.</p>
                                            </div>
                                        </div>

                                        <!-- Mua Bán Linh Hoạt -->
                                        <div class="col-md-4">
                                            <div class="feature-card p-4 border rounded shadow-lg">
                                                <div class="video-container mb-3">
                                                    <video class="w-100 rounded" autoplay loop muted controls>
                                                        <source src="~/images/Muaca.mp4" type="video/mp4">
                                                        Your browser does not support the video tag.
                                                    </video>
                                                </div>
                                                <h4 class="mt-3">Mua Bán Linh Hoạt</h4>
                                                <p>Hệ thống mua bán và ký gửi minh bạch, dễ dàng.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                    </section>

                </div>
</section>

<!-- Koi Showa -->
<div class="image-video-container" style="position: relative; display: inline-block; width: 100%; height: auto;">
    <!-- Hình ảnh nền -->
    <img src="~/images/showa.jpg" class="image" alt="Hình ảnh nền" style="width: 100%; height: auto;">

    <!-- Video nằm ngang bên trái hình ảnh -->
