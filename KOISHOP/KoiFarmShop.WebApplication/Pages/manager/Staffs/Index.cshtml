@page
@model KoiFarmShop.WebApplication.Pages.manager.Staffs.IndexModel
@{
    ViewData["Title"] = "Quản lý Nhân viên";
    Layout = "~/Pages/Shared/_ManagerLayout.cshtml"; // Sử dụng layout của Admin
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách nhân viên</h6>
        <a asp-page="Create" class="btn btn-success btn-sm"><i class="fas fa-plus"></i> Thêm nhân viên</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                <thead class="thead-dark">
                    <tr>
                        <th>ID</th>
                        <th>Họ và tên</th>
                        <th>Điện thoại</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.StaffList != null && Model.StaffList.Count > 0)
                    {
                        foreach (var item in Model.StaffList)
                        {
                            <tr>
                                <td>@item.StaffId</td>
                                <td>@item.StaffName</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td><span class="badge bg-info text-dark">@item.Role</span></td>
                                <td>
                                    <a asp-page="./Edit" asp-route-id="@item.StaffId" class="btn btn-warning btn-sm">Sửa</a>
                                    <a asp-page="./Delete" asp-route-id="@item.StaffId" class="btn btn-danger btn-sm">Xóa</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">Chưa có dữ liệu nhân viên.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

