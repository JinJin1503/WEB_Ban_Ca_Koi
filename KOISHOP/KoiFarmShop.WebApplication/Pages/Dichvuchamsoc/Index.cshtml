@page
@model KoiFarmShop.WebApplication.Pages.Dichvu.IndexModel

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ký gửi cá Koi</title>
    <!-- Đảm bảo đã bao gồm Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container py-5">
        <h1 class="text-center mb-4">Dịch vụ ký gửi chăm sóc cá Koi</h1>
        <div class="row justify-content-center">
            <!-- Thông tin ký gửi -->
            <div class="col-md-8 col-lg-6">
                <h3 class="mb-3 text-center">Thông tin ký gửi</h3>
                <form>
                    <div class="mb-3">
                        <label for="KoiName" class="form-label">Tên cá</label>
                        <input type="text" class="form-control" id="KoiName" name="KoiName" required />
                    </div>
                    <div class="mb-3">
                        <label for="KoiAge" class="form-label">Tuổi cá (năm)</label>
                        <input type="number" class="form-control" id="KoiAge" name="KoiAge" required />
                    </div>
                    <div class="mb-3">
                        <label for="KoiSize" class="form-label">Kích thước cá (cm)</label>
                        <input type="number" class="form-control" id="KoiSize" name="KoiSize" required />
                    </div>
                    <div class="mb-3">
                        <label for="KoiBreed" class="form-label">Giống cá</label>
                        <select class="form-select" id="KoiBreed" name="KoiBreed" required>
                            <option value="Imported">Nhập khẩu</option>
                            <option value="Domestic">Thuần Việt</option>
                            <option value="Hybrid">Lai F1</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="ConsignmentDate" class="form-label">Ngày ký gửi</label>
                        <input type="date" class="form-control" id="ConsignmentDate" name="ConsignmentDate" required />
                    </div>
                    <div class="mb-3">
                        <label for="ConsignmentDuration" class="form-label">Thời gian ký gửi</label>
                        <select class="form-select" id="ConsignmentDuration" name="ConsignmentDuration" required>
                            <option value="1">1 tháng</option>
                            <option value="3">3 tháng</option>
                            <option value="6">6 tháng</option>
                            <option value="12">12 tháng</option>
                        </select>
                    </div>
                    <!-- Lựa chọn dịch vụ bảo vệ và chăm sóc -->
                    <div class="mb-3">
                        <label class="form-label">Dịch vụ chăm sóc cá</label>
                        <div>
                            <input type="checkbox" id="CareService" name="CareService" />
                            <label for="CareService" class="ms-2">Chăm sóc đặc biệt</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="Remarks" class="form-label">Mô tả cá</label>
                        <textarea class="form-control" id="Remarks" name="Remarks" rows="3"></textarea>
                    </div>

                    <!-- Thêm ảnh cá -->
                    <div class="mb-3">
                        <label for="KoiImage" class="form-label">Ảnh cá</label>
                        <input type="file" class="form-control" id="KoiImage" name="KoiImage" />
                    </div>

                    <div class="mb-3 text-center">
                        <button type="submit" class="btn btn-success">Xác nhận ký gửi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>