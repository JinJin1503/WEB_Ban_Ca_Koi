@page
@model KoiFarmShop.WebApplication.Pages.Manager.Consignment.DetailsConsignmentModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Chi Tiết Đơn Ký Gửi";
    ViewData["HideDashboard"] = true;
}
@functions {
    string GetStatusBadgeClass(string status)
    {
        return (status?.ToLower()) switch
        {
            "approved" or "đã duyệt" => "bg-primary",
            "pending" or "chờ duyệt" => "bg-warning text-dark",
            "đã nhận cá" => "bg-info text-dark",
            "đang chăm sóc" => "bg-secondary",
            "đã bán" => "bg-success",
            "hoàn thành" => "bg-success",
            "rejected" or "từ chối" => "bg-danger",
            _ => "bg-light text-dark"
        };
    }

    string TranslateStatus(string status)
    {
        return (status?.ToLower()) switch
        {
            "approved" => "Đã duyệt",
            "rejected" => "Từ chối",
            "pending" => "Chờ duyệt",
            _ => status ?? "Không xác định"
        };
    }
    string TranslateCategory(string category)
    {
        if (string.IsNullOrEmpty(category)) return "Không xác định";
        return category.ToLower() switch
        {
            "imported" => "Nhập khẩu",
            "domestic" => "Thuần Việt",
            "hybrid" => "Lai F1",
            _ => category
        };
    }
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Chi Tiết Đơn Ký Gửi #@Model.ConsignmentRequest.RequestId</h2>
        <a href="/manager/Consignment/ManageConsignment" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Thông Tin Chung</h5>
                </div>
                <div class="card-body">
                    <p><strong>Khách hàng:</strong> @Model.ConsignmentRequest.Customer?.CustomerName</p>
                    <p>
                        <strong>Loại dịch vụ:</strong>
                        <span class="badge @(Model.ConsignmentRequest.ConsignmentType == "Bán" ? "bg-info" : "bg-success")">
                            @Model.ConsignmentRequest.ConsignmentType
                        </span>
                    </p>
                    <p><strong>Ngày gửi yêu cầu:</strong> @Model.ConsignmentRequest.RequestDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p>
                        <strong>Trạng thái hiện tại:</strong>
                        <span class="badge @GetStatusBadgeClass(Model.ConsignmentRequest.Status)">
                            @TranslateStatus(Model.ConsignmentRequest.Status)
                        </span>
                    </p>
                    @if (Model.ConsignmentRequest.CareService)
                    {
                        <p><strong>Yêu cầu đặc biệt:</strong> <span class="text-danger fw-bold">Có sử dụng dịch vụ chăm sóc</span></p>
                    }
                    <p class="mb-1">
                        <strong>@(Model.ConsignmentRequest.ConsignmentType == "Bán" ? "Giá khách muốn bán:" : "Phí dịch vụ:")</strong>
                        <span class="text-danger fw-bold fs-5">@Model.ConsignmentRequest.ConsignmentFee.ToString("N0") VNĐ</span>
                    </p>
                    <p class="mb-0">
                        <strong>Ghi chú từ cửa hàng:</strong>
                        <span class="text-primary fst-italic">@(string.IsNullOrEmpty(Model.ConsignmentRequest.Notes) ? "Không có" : Model.ConsignmentRequest.Notes)</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-fish"></i> Hồ Sơ Cá Koi</h5>
                </div>
                <div class="card-body">
                    <p><strong>Tên cá:</strong> @Model.ConsignmentRequest.KoiName</p>
                    <p><strong>Giống cá:</strong> @TranslateCategory(Model.ConsignmentRequest.KoiBreed)</p>
                    <p><strong>Tuổi:</strong> @Model.ConsignmentRequest.KoiAge tháng</p>
                    <p><strong>Kích thước:</strong> @Model.ConsignmentRequest.KoiSize cm</p>
                    <p>
                        <strong>Mô tả chi tiết:</strong>
                        @if (!string.IsNullOrWhiteSpace(Model.ConsignmentRequest.Remarks))
                        {
                            <span>@Model.ConsignmentRequest.Remarks</span>
                        }
                        else
                        {
                            <span class="fst-italic text-muted">Không có mô tả thêm</span>
                        }
                    </p>
                    <hr />
                    <p class="mb-2"><strong>Hình ảnh đính kèm:</strong></p>
                    @if (!string.IsNullOrEmpty(Model.ConsignmentRequest.KoiImage))
                    {
                        <div class="text-center">
                            <img src="@Model.ConsignmentRequest.KoiImage" alt="Ảnh cá Koi ký gửi" class="img-fluid rounded shadow" style="max-height: 350px; object-fit: cover;" />
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary text-center py-2 mb-0" role="alert">
                            <i class="fas fa-image text-muted me-2"></i>
                            <span class="fst-italic text-muted">Khách hàng không gửi hình ảnh</span>
                        </div>
                    }
                    @if (Model.ConsignmentRequest.ConsignmentType == "Chăm sóc" &&
                                        (Model.ConsignmentRequest.Status == "Đang chăm sóc" || Model.ConsignmentRequest.Status == "Hoàn thành"))
                    {
                        var startDate = Model.ConsignmentRequest.ConsignmentDate;
                        // Lưu ý: Nếu ConsignmentDuration  tính bằng NGÀY thì đổi AddMonths thành AddDays nhé
                        var endDate = startDate.AddMonths(Model.ConsignmentRequest.ConsignmentDuration);
                        var today = DateTime.Now;

                        var totalDays = (endDate - startDate).TotalDays;
                        var daysPassed = (today - startDate).TotalDays;

                        // Xử lý các trường hợp vượt giới hạn
                        if (daysPassed < 0) daysPassed = 0;
                        if (daysPassed > totalDays) daysPassed = totalDays;

                        var percent = totalDays > 0 ? (daysPassed / totalDays) * 100 : 0;
                        var daysLeft = Math.Max(0, Math.Ceiling((endDate - today).TotalDays));

                        <hr />
                        <div class="mt-3 bg-light p-3 rounded border">
                            <h6 class="fw-bold text-primary mb-3">
                                <i class="fas fa-calendar-check me-2"></i>Tiến độ chăm sóc
                            </h6>

                            <div class="d-flex justify-content-between mb-1" style="font-size: 0.85rem;">
                                <span class="text-muted">Bắt đầu: <strong>@startDate.ToString("dd/MM/yyyy")</strong></span>
                                @if (daysLeft > 0)
                                {
                                    <span class="text-danger fw-bold heartbeat">Còn lại: @daysLeft ngày</span>
                                }
                                else
                                {
                                    <span class="text-success fw-bold">Đã hết hạn chăm sóc</span>
                                }
                                <span class="text-muted">Kết thúc: <strong>@endDate.ToString("dd/MM/yyyy")</strong></span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <progress value="@((int)percent)" max="100" class="w-100" style="height: 20px; border-radius: 5px; flex-grow: 1;" title="@Math.Round(percent)% hoàn thành"></progress>
                                <span class="fw-bold" style="font-size: 0.85rem;">@Math.Round(percent)%</span>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="ConsignmentRequest.RequestId" name="id" />

        <div class="mt-4 mb-4">
            @{
                var currentStatus = Model.ConsignmentRequest.Status?.ToLower();
            }
            @if (currentStatus == "chờ duyệt" || currentStatus == "pending")
            {
                <div class="mb-4 border border-primary p-3 rounded bg-primary-subtle bg-opacity-10 shadow-sm">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-edit me-2"></i>Báo giá & Phản hồi (Dành cho Admin)</h6>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            @if (Model.ConsignmentRequest.ConsignmentType == "Chăm sóc")
                            {
                                <label class="form-label fw-bold">Báo giá dịch vụ (VNĐ):</label>
                                <input type="number" name="fee" class="form-control border-primary" placeholder="Ví dụ: 500000" min="0" required />
                                <small class="text-muted">Bắt buộc nhập phí</small>
                            }
                            else
                            {
                                <label class="form-label fw-bold">Giá khách muốn bán:</label>
                                <input type="number" class="form-control border-primary bg-light mb-2" value="@Model.ConsignmentRequest.ConsignmentFee" disabled />

                                <label class="form-label fw-bold text-warning"><i class="fas fa-percentage me-1"></i>Hoa hồng Shop (%):</label>
                                <input type="number" name="commission" class="form-control border-warning" placeholder="VD: 10" min="0" max="100" required />
                                <small class="text-muted">Tỉ lệ chiết khấu cho cửa hàng</small>
                            }
                        </div>

                        <div class="col-md-8 mb-3">
                            <label class="form-label fw-bold">Ghi chú cho khách hàng:</label>
                            <textarea name="notes" class="form-control border-primary" rows="2" placeholder="Ví dụ: Cá đạt chuẩn, cửa hàng đồng ý nhận bán..."></textarea>
                        </div>
                    </div>

                    <div class="mt-2">
                        <button type="submit" asp-page-handler="Approve" class="btn btn-success me-2 fw-bold">
                            <i class="fas fa-check-circle me-1"></i> Phê duyệt & Gửi báo giá
                        </button>
                        <button type="submit" asp-page-handler="Reject" class="btn btn-danger fw-bold" formnovalidate>
                            <i class="fas fa-times-circle me-1"></i> Từ chối
                        </button>
                    </div>
                </div>
            }
            else if (currentStatus == "approved" || currentStatus == "đã duyệt")
            {
                <button type="submit" asp-page-handler="ReceiveKoi" class="btn btn-info text-white">Xác nhận: Đã nhận cá</button>
            }
            else if (currentStatus == "đã nhận cá")
            {
                // LOGIC PHÂN LUỒNG NGHIỆP VỤ Ở ĐÂY
                @if (Model.ConsignmentRequest.ConsignmentType == "Bán")
                {
                    <button type="submit" asp-page-handler="Sold" class="btn btn-warning">Xác nhận: Đã bán</button>
                }
                else if (Model.ConsignmentRequest.ConsignmentType == "Chăm sóc")
                {
                    <button type="submit" asp-page-handler="StartCare" class="btn btn-primary me-2">Đưa vào chăm sóc</button>
                }
            }
        </div>
    </form>
