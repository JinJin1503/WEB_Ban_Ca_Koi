<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang chủ - Koi Farm</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="container" style="width: 90%; margin: 0 auto; padding: 20px;">
        <!-- Blog Chia Sẻ -->
        <div class="blog-news-section">
            <h2 style="text-align: center; font-size: 24px; font-weight: bold; color: #333;">Blog Chia Sẻ</h2>
            <div style="display: flex; flex-wrap: wrap; justify-content: space-between;">
                <div class="blog-item" style="width: 48%; margin-bottom: 20px;">
                    <img src="/images/blog1.jpg" alt="Cách chăm sóc cá Koi mùa đông" style="width: 100%; height: auto; border-radius: 8px;" />
                    <h3 style="font-size: 20px; margin-top: 10px; font-weight: bold; color: #333;">Cách chăm sóc cá Koi mùa đông</h3>
                    <p style="color: #666;">Hướng dẫn cách giữ nhiệt độ nước ổn định trong mùa đông để cá Koi khỏe mạnh và phát triển tốt.</p>
                </div>

                <div class="blog-item" style="width: 48%; margin-bottom: 20px;">
                    <img src="/images/blog2.jpg" alt="Phòng bệnh cho cá Koi" style="width: 100%; height: auto; border-radius: 8px;" />
                    <h3 style="font-size: 20px; margin-top: 10px; font-weight: bold; color: #333;">Phòng bệnh cho cá Koi</h3>
                    <p style="color: #666;">Cách nhận diện và phòng ngừa các bệnh thường gặp ở cá Koi giúp chúng luôn khỏe mạnh.</p>
                </div>
            </div>
        </div>

        <!-- Tin Tức -->
        <div class="news-section" style="margin-top: 40px;">
            <h2 style="text-align: center; font-size: 24px; font-weight: bold; color: #333;">Tin Tức</h2>
            <div style="display: flex; flex-wrap: wrap; justify-content: space-between;">
                <div class="news-item" style="width: 48%; margin-bottom: 20px;">
                    <img src="/images/news1.png" alt="Sự kiện cá Koi quốc tế 2024" style="width: 100%; height: auto; border-radius: 8px;" />
                    <h3 style="font-size: 20px; margin-top: 10px; font-weight: bold; color: #333;">Sự kiện cá Koi quốc tế 2024</h3>
                    <p style="color: #666;">Thông tin mới nhất về sự kiện cá Koi lớn nhất trong năm sẽ diễn ra tại Việt Nam vào tháng 6.</p>
                </div>

                <div class="news-item" style="width: 48%; margin-bottom: 20px;">
                    <img src="/images/new2.jpg" alt="Hồ cá Koi tại Việt Nam" style="width: 100%; height: auto; border-radius: 8px;" />
                    <h3 style="font-size: 20px; margin-top: 10px; font-weight: bold; color: #333;">Hồ cá Koi tại Việt Nam</h3>
                    <p style="color: #666;">Giới thiệu về các hồ cá Koi tại Việt Nam.</p>
                </div>
            </div>
        </div>
    </div>
</body>
